{
  "name": "Smoke Effect",
  "version": "9.0.0",
  "description": "Simple animated smoke overlay with clean visual controls and no runtime permissions.",
  "author": "MyWallpaper Community",
  "type": "widget",
  "entry": "index.js",
  "categories": [
    "effects",
    "animations",
    "backgrounds"
  ],
  "license": "MIT",
  "repository": "https://github.com/MyWallpapers/mywallpaper-addon-smoke-effect",
  "settings": {
    "color": {
      "type": "color",
      "content": {
        "label": "Smoke color",
        "default": "#FFFFFF"
      }
    },
    "randomizeColor": {
      "type": "button",
      "content": {
        "buttonLabel": "Randomize color"
      }
    },
    "style": {
      "type": "select",
      "content": {
        "label": "Smoke style",
        "default": "classic",
        "options": [
          {
            "label": "Soft mist",
            "value": "soft"
          },
          {
            "label": "Classic smoke",
            "value": "classic"
          },
          {
            "label": "Dense cloud",
            "value": "dense"
          },
          {
            "label": "Storm flow",
            "value": "storm"
          }
        ]
      }
    },
    "intensity": {
      "type": "range",
      "content": {
        "label": "Intensity",
        "description": "Overall smoke visibility.",
        "default": 0.7,
        "min": 0,
        "max": 1,
        "step": 0.01
      }
    },
    "motion": {
      "type": "range",
      "content": {
        "label": "Motion",
        "description": "Animation speed and flow energy.",
        "default": 0.35,
        "min": 0,
        "max": 1,
        "step": 0.01
      }
    },
    "size": {
      "type": "range",
      "content": {
        "label": "Smoke size",
        "description": "Small wisps to large clouds.",
        "default": 0.55,
        "min": 0,
        "max": 1,
        "step": 0.01
      }
    },
    "direction": {
      "type": "select",
      "content": {
        "label": "Direction",
        "default": "up",
        "options": [
          {
            "label": "Up",
            "value": "up"
          },
          {
            "label": "Right",
            "value": "right"
          },
          {
            "label": "Down",
            "value": "down"
          },
          {
            "label": "Left",
            "value": "left"
          }
        ]
      }
    },
    "quality": {
      "type": "select",
      "content": {
        "label": "Quality",
        "default": "balanced",
        "options": [
          {
            "label": "Performance",
            "value": "performance"
          },
          {
            "label": "Balanced",
            "value": "balanced"
          },
          {
            "label": "High",
            "value": "high"
          }
        ]
      }
    }
  },
  "defaultLayout": {
    "xPercent": 0,
    "yPercent": 0,
    "widthPercent": 100,
    "heightPercent": 100,
    "rotation": 0
  },
  "ui": {
    "pointerEvents": "none"
  }
}
